{
    "sourceList": {
        "animeSources": [
            {
                "featureID": "web-selector",
                "version": "1.0",
                "config": {
                    "name": "异世界动漫",
                    "baseUrl": "https://dmmiku.com/",
                    "iconUrl": "https://dmmiku.com/template/conch/asset/img/favicon.png",
                    "searchConfig": {
                        "searchUrl": "https://dmmiku.com/index.php/vod/search.html?wd={keyword}",
                        "selectorName": "body > div.container > div.left_row.fl > div.pannel.search_box.clearfix > ul > li > div.searchlist_titbox > h4 > a",
                        "selectorLink": "body > div.container > div.left_row.fl > div.pannel.search_box.clearfix > ul > li > div.searchlist_titbox > h4 > a"
                    },
                    "episodeConfig": {
                        "isMultiLine": true,
                        "selectorLineName": "#NumTab > a",
                        "selectorLineLink": "#bofy > div.play_source > div.play_list_box.hide > div.playlist_full > ul",
                        "selectorEpisodeName": "li > a",
                        "selectorEpisodeLink": "li > a",
                        "matchVideoSubUrl": ""
                    },
                    "expansionConfig": {
                        "parserConfig": {
                            "type": "HTML-Parser",
                            "selectorTag": "body > div.container > div.left_row.fl > div.pannel.play_box.clearfix > div.play_box_warp > div.play_box_warp2 > script:nth-child(6)",
                            "matchVideoUrl": "",
                            "parserMode": "tuzimi"
                        }
                    }
                    
                }
            }                       
        ]
    }
}